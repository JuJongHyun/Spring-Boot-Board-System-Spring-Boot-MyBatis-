<configuration>

    <appender name="console" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>[%level] %logger - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- 전체 기본 로그 -->
    <root level="INFO">
        <appender-ref ref="console"/>
    </root>

    <!-- 인터셉터 로그 -->
    <logger name="com.study.interceptor" level="DEBUG" additivity="false">
        <appender-ref ref="console"/>
    </logger>

    <!-- 애플리케이션 일반 로그 (서비스/컨트롤러) -->
    <logger name="com.study" level="INFO" additivity="false">
        <appender-ref ref="console"/>
    </logger>

    <!-- AOP 로그-->
    <logger name="com.study.aop.LoggerAspect" level="DEBUG" additivity="false">
        <appender-ref ref="console"/>
    </logger>

    <!-- SQL 로그 (실행 쿼리 출력) -->
    <logger name="jdbc.sqlonly" level="INFO" additivity="false">
        <appender-ref ref="console"/>
    </logger>

    <!-- SQL 결과 테이블 출력 -->
    <logger name="jdbc.resultsettable" level="INFO" additivity="false">
        <appender-ref ref="console"/>
    </logger>

    <!-- JDBC 상세 로그 비활성화 (불필요 로그 제거) -->
    <logger name="jdbc.audit" level="OFF"/>
    <logger name="jdbc.resultset" level="OFF"/>
    <logger name="jdbc.connection" level="OFF"/>
    <logger name="jdbc.sqltiming" level="OFF"/>

</configuration>

